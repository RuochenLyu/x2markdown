{
  "manifest_version": 3,
  "name": "X2Markdown",
  "description": "在受支持的 x.com 页面右键复制为 Markdown，一键整理标题、作者、时间、正文和图片链接。",
  "version": "1.1.0",
  "permissions": [
    "activeTab",
    "clipboardWrite",
    "contextMenus",
    "scripting"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://x.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "content.css"
      ],
      "run_at": "document_idle"
    }
  ]
}
